# ─────────────────────────────────────────────────────────────────────────────
# INCOMIA — Variables de Entorno del Frontend
#
# Copia este archivo como .env y llena los valores con los outputs de Terraform.
# Los outputs los genera: infrastructure/outputs.tf
#
# ⚠ Nunca subas el archivo .env al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS API Gateway ───────────────────────────────────────────────────────────
# URL base del API HTTP de API Gateway (sin trailing slash)
# Ejemplo: https://abc123.execute-api.us-east-1.amazonaws.com
VITE_API_BASE_URL=

# ── AWS Cognito ───────────────────────────────────────────────────────────────
# ID del User Pool (output: cognito_user_pool_id)
# Ejemplo: us-east-1_ABC123XYZ
VITE_COGNITO_USER_POOL_ID=

# ID del App Client del User Pool (output: cognito_client_id)
# Ejemplo: 3abc123defgh456ijkl789
VITE_COGNITO_CLIENT_ID=

# ── Modo de desarrollo ────────────────────────────────────────────────────────
# Si VITE_API_BASE_URL está vacía, el servicio usa datos mock automáticamente.
# No se necesita configurar nada adicional para desarrollo offline.
